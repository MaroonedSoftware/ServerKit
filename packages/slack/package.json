{
  "name": "@maroonedsoftware/slack",
  "version": "2.0.0",
  "description": "Slack utilities for ServerKit.",
  "author": {
    "name": "Marooned Software",
    "url": "https://github.com/MaroonedSoftware/serverkit"
  },
  "bugs": {
    "url": "https://github.com/MaroonedSoftware/serverkit/issues"
  },
  "homepage": "https://github.com/MaroonedSoftware/serverkit/packages/slack#readme",
  "keywords": [
    "backend",
    "slack",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./comms": {
      "types": "./dist/comms.d.ts",
      "import": "./dist/comms.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/comms.ts --format esm --sourcemap && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/logger": "workspace:*",
    "@maroonedsoftware/policies": "workspace:*",
    "@slack/web-api": "^7.17.0",
    "injectkit": "^1.5.0",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@maroonedsoftware/comms": "workspace:*",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/luxon": "^3.7.2"
  },
  "peerDependencies": {
    "@maroonedsoftware/comms": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@maroonedsoftware/comms": {
      "optional": true
    }
  }
}
