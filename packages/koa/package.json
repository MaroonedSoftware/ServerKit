{
  "name": "@maroonedsoftware/koa",
  "version": "1.9.0",
  "description": "Koa middleware, body parsing, and utilities for ServerKit",
  "author": {
    "name": "Marooned Software",
    "url": "https://github.com/MaroonedSoftware/serverkit"
  },
  "bugs": {
    "url": "https://github.com/MaroonedSoftware/serverkit/issues"
  },
  "homepage": "https://github.com/MaroonedSoftware/serverkit/packages/koa#readme",
  "keywords": [
    "backend",
    "koa",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --dts && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@hapi/bourne": "^3.0.0",
    "@maroonedsoftware/appconfig": "workspace:*",
    "@maroonedsoftware/authentication": "workspace:*",
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/logger": "workspace:*",
    "@maroonedsoftware/multipart": "workspace:*",
    "@maroonedsoftware/utilities": "workspace:*",
    "co-body": "^6.2.0",
    "inflation": "^2.1.0",
    "injectkit": "^1.1.3",
    "qs": "^6.15.0",
    "rate-limiter-flexible": "^10.0.1",
    "raw-body": "^3.0.2"
  },
  "peerDependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.2.0",
    "koa": "^3.1.1"
  },
  "devDependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/co-body": "^6.1.3",
    "@types/inflation": "^2.0.4",
    "@types/koa": "^3.0.2",
    "@types/koa__cors": "^5.0.1",
    "@types/qs": "^6.15.0",
    "koa": "^3.2.0"
  }
}
