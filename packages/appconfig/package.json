{
  "name": "@maroonedsoftware/appconfig",
  "version": "2.2.0",
  "description": "A flexible, type-safe configuration management library with support for multiple sources and value transformation.",
  "author": {
    "name": "Marooned Software",
    "url": "https://github.com/MaroonedSoftware/serverkit"
  },
  "bugs": {
    "url": "https://github.com/MaroonedSoftware/serverkit/issues"
  },
  "homepage": "https://github.com/MaroonedSoftware/serverkit/packages/appconfig#readme",
  "keywords": [
    "backend",
    "configuration",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    },
    "./yaml": {
      "types": "./dist/yaml.d.ts",
      "import": "./dist/yaml.js"
    },
    "./aws": {
      "types": "./dist/aws.d.ts",
      "import": "./dist/aws.js"
    },
    "./gcp": {
      "types": "./dist/gcp.d.ts",
      "import": "./dist/gcp.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/postgres.ts src/yaml.ts src/aws.ts src/gcp.ts --format esm --sourcemap && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/logger": "workspace:*",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.4.2",
    "injectkit": "^1.6.0"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1077.0",
    "@google-cloud/secret-manager": "^6.2.0",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1057.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "pg": "^8.21.0",
    "yaml": "^2.8.2"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-secrets-manager": {
      "optional": true
    },
    "@google-cloud/secret-manager": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
