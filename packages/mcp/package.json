{
  "name": "@maroonedsoftware/mcp",
  "version": "0.0.1",
  "description": "Model Context Protocol (MCP) server dispatcher for ServerKit.",
  "author": {
    "name": "Marooned Software",
    "url": "https://github.com/MaroonedSoftware/serverkit"
  },
  "bugs": {
    "url": "https://github.com/MaroonedSoftware/serverkit/issues"
  },
  "homepage": "https://github.com/MaroonedSoftware/serverkit/packages/mcp#readme",
  "keywords": [
    "backend",
    "mcp",
    "model-context-protocol",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/logger": "workspace:*",
    "@maroonedsoftware/policies": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "injectkit": "^1.6.0"
  },
  "devDependencies": {
    "@maroonedsoftware/cache": "workspace:*",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*"
  },
  "peerDependencies": {
    "@maroonedsoftware/cache": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@maroonedsoftware/cache": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
