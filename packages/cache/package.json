{
  "name": "@maroonedsoftware/cache",
  "version": "0.2.0",
  "description": "Cache utilities for ServerKit.",
  "keywords": [
    "backend",
    "cache",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ioredis": {
      "types": "./dist/ioredis.d.ts",
      "import": "./dist/ioredis.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/ioredis.ts --format esm --sourcemap && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/utilities": "workspace:*",
    "injectkit": "^1.5.0",
    "luxon": "^3.7.2",
    "rate-limiter-flexible": "^11.2.0"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/luxon": "^3.7.2",
    "ioredis": "^5.11.1"
  },
  "peerDependencies": {
    "ioredis": "^5.10.1"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
