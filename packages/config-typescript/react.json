{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["es2025", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "target": "ES2025",
    "moduleResolution": "Bundler",
    "module": "esnext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true
  }
}
