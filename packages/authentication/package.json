{
  "name": "@maroonedsoftware/authentication",
  "version": "0.3.0",
  "description": "Authentication utilities for ServerKit.",
  "keywords": [
    "backend",
    "authentication",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --dts && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/logger": "workspace:*",
    "injectkit": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1"
  }
}
