{
  "name": "@maroonedsoftware/authentication",
  "version": "4.29.1",
  "description": "Authentication utilities for ServerKit.",
  "keywords": [
    "backend",
    "authentication",
    "serverkit",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaroonedSoftware/serverkit.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap && tsc --emitDeclarationOnly --declaration",
    "build:ci": "eslint --max-warnings=0 && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@maroonedsoftware/cache": "workspace:*",
    "@maroonedsoftware/encryption": "workspace:*",
    "@maroonedsoftware/errors": "workspace:*",
    "@maroonedsoftware/logger": "workspace:*",
    "@maroonedsoftware/policies": "workspace:*",
    "@maroonedsoftware/utilities": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "@zxcvbn-ts/matcher-pwned": "^4.1.2",
    "arctic": "^3.7.0",
    "deepmerge-ts": "^7.1.5",
    "fido2-lib": "^3.5.9",
    "injectkit": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "openid-client": "^6.8.4",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^11.2.0",
    "zxcvbn-ts": "^2.3.0"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.2",
    "@types/qrcode": "^1.5.6"
  },
  "engines": {
    "node": ">=22"
  }
}
