{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": ["CI", "JOHNNY5_NON_INTERACTIVE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "build:ci": {
      "dependsOn": ["^build:ci"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "format": {},
    "test": {
      "dependsOn": ["^test", "build"]
    },
    "test:ci": {
      "dependsOn": ["^test:ci"]
    },
    "vscode:install": {
      "dependsOn": ["build"],
      "cache": false
    },
    "vscode:uninstall": {
      "dependsOn": ["^vscode:uninstall"]
    }
  }
}
